# =============================================================================
# Dashboard FinFlow — Nextwear S.L.  ·  variables de entorno
# Copia este fichero a `.env.local` y rellena los valores. `.env.local` está
# ignorado por git (ver .gitignore). NUNCA subas claves reales al repo.
# =============================================================================

# --- Supabase -----------------------------------------------------------------
# URL pública del proyecto (segura para el cliente).
NEXT_PUBLIC_SUPABASE_URL=https://rnmidwhumdrpxulfsbjo.supabase.co

# Service role key: SECRETA. Solo se usa en route handlers del backend.
# Salta RLS — jamás debe exponerse al cliente ni subirse al repo.
# Obtenerla en: Supabase → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# (Opcional) anon/publishable key — solo si el cliente necesitara acceso directo.
# Este dashboard NO la usa: todo pasa por el backend con service role.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Copiloto LLM (SIN CONECTAR todavía) --------------------------------------
# El proveedor se decidirá más adelante (Claude / OpenAI / Gemini / otro).
# Mientras estas variables estén vacías, el copiloto funciona en modo mock.
# LLM_PROVIDER=            # claude | openai | gemini | ...
# LLM_API_KEY=
# LLM_MODEL=
